{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.badmintoncourt.store",
        "EXPO_PUBLIC_KAKAO_REST_KEY": "REPLACE_WITH_KAKAO_KEY"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.badmintoncourt.store",
        "EXPO_PUBLIC_KAKAO_REST_KEY": "REPLACE_WITH_KAKAO_KEY"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
