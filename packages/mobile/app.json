{
  "expo": {
    "name": "배드민턴 코트",
    "slug": "badminton-court",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "badminton",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gylee.badminton",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "QR코드 체크인을 위해 카메라 접근이 필요합니다",
        "NSLocationWhenInUseUsageDescription": "주변 체육관을 찾기 위해 위치 정보가 필요합니다"
      }
    },
    "android": {
      "package": "com.gylee.badminton",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "https://api.badmintoncourt.store",
      "kakaoRestKey": "5a202bd90ab8dff01348f24cb1c37f3f",
      "googleClientId": "REPLACE_WITH_GOOGLE_CLIENT_ID",
      "eas": {
        "projectId": "ad8ee9b9-c892-4ebe-bfec-b8df01ea405b"
      },
      "router": {}
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "QR코드 체크인을 위해 카메라 접근이 필요합니다"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "주변 체육관을 찾기 위해 위치 정보가 필요합니다"
        }
      ]
    ],
    "owner": "leegyoungyoon"
  }
}
