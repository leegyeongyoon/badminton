generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  FACILITY_ADMIN
  CLUB_LEADER
  PLAYER
}

enum OperatorRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CourtStatus {
  EMPTY
  IN_USE
  MAINTENANCE
}

enum GameStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TurnStatus {
  WAITING
  PLAYING
  COMPLETED
  CANCELLED
}

enum SkillLevel {
  S // 선수출신
  A // 상
  B // 중상
  C // 중
  D // 중하
  E // 초심
  F // 왕초심
}

enum GameType {
  SINGLES
  DOUBLES
  MIXED_DOUBLES
}

enum CourtGameType {
  DOUBLES
  LESSON
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum ClubMemberRole {
  LEADER
  STAFF
  MEMBER
}

enum ClubSessionStatus {
  ACTIVE
  ENDED
}

enum ChatMessageType {
  CHAT
  REQUEST
}

model User {
  id            String   @id @default(uuid())
  phone         String?  @unique
  password      String?
  kakaoId       String?  @unique
  name          String
  role          UserRole @default(PLAYER)
  isGuest       Boolean  @default(false)
  // Operator-managed club member: a real, PERSISTENT club member with no app
  // login (운영자가 등록한 멤버). Unlike a session guest (isGuest=true, vanishes
  // when the 정모 ends), a managed member keeps its ClubMember row and shows in
  // the roster across 정모s. The operator just takes attendance each 정모.
  isManaged     Boolean  @default(false)
  expoPushToken String?
  refreshToken  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  facilityAdmins      FacilityAdmin[]
  checkIns            CheckIn[]
  clubMembers         ClubMember[]
  gamePlayers         GamePlayer[]
  notifications       Notification[]
  profile             PlayerProfile?
  noShowRecords       NoShowRecord[]
  openedSessions      FacilitySession[]   @relation("SessionOpener")
  createdTurns        CourtTurn[]         @relation("TurnCreator")
  turnPlayers         TurnPlayer[]
  startedClubSessions ClubSession[]       @relation("ClubSessionStarter")
  createdGameBoards   GameBoard[]         @relation("GameBoardCreator")
  clubMessages        ClubMessage[]
  operatorRequests    OperatorRequest[]   @relation("OperatorRequester")
}

// 운영자(모임 생성 권한) 신청. PLAYER 가 운영자 권한을 신청하면 SUPER_ADMIN 이
// 승인/거절한다. 승인 시 해당 User.role 이 CLUB_LEADER 로 바뀐다. 한 유저는
// 동시에 PENDING 신청을 하나만 가질 수 있다(코드에서 enforce).
model OperatorRequest {
  id           String                @id @default(uuid())
  userId       String
  status       OperatorRequestStatus @default(PENDING)
  message      String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime              @default(now())

  user User @relation("OperatorRequester", fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

model PlayerProfile {
  id                 String     @id @default(uuid())
  userId             String     @unique
  skillLevel         SkillLevel?
  preferredGameTypes GameType[] @default([DOUBLES])
  gender             String?
  birthYear          Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Facility {
  id         String   @id @default(uuid())
  name       String
  address    String
  latitude   Float?
  longitude  Float?
  qrCodeData String   @unique @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  courts        Court[]
  admins        FacilityAdmin[]
  checkIns      CheckIn[]
  policy        FacilityPolicy?
  noShowRecords NoShowRecord[]
  sessions      FacilitySession[]
  homeClubs     Club[]
  clubSessions  ClubSession[]
  gameBoards    GameBoard[]
}

model FacilityPolicy {
  id                   String   @id @default(uuid())
  facilityId           String   @unique
  maxTurnsPerCourt     Int      @default(3)
  playersPerTurn       Int      @default(4)
  allowRequeue         Boolean  @default(true)
  noShowPenaltyMinutes Int      @default(30)
  turnNotifyEnabled    Boolean  @default(true)
  gameDurationMinutes  Int?
  gameWarningMinutes   Int?     @default(2)
  checkinRadiusM       Int      @default(100)
  checkinWindowMinutes Int?     @default(60)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
}

model Court {
  id            String        @id @default(uuid())
  name          String
  facilityId    String
  // Per-정모 ownership. A court belongs to ONE ClubSession (코트1·2·3 등). Each 정모
  // names its own courts independently and never sees another 정모's courts.
  // clubSessionId = null → a facility-level court (facility-admin dashboard).
  clubSessionId String?
  status        CourtStatus   @default(EMPTY)
  gameType      CourtGameType @default(DOUBLES)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  facility         Facility         @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  clubSession      ClubSession?     @relation(fields: [clubSessionId], references: [id], onDelete: Cascade)
  turns            CourtTurn[]
  games            Game[]
  gameBoardEntries GameBoardEntry[]

  // Each 정모 names its courts independently (코트1·2·3) — same names across 정모s
  // never collide. Facility-level courts (clubSessionId = null) are not constrained
  // by this composite (null sessions don't participate in the unique).
  @@unique([clubSessionId, name])
  @@index([clubSessionId])
}

model FacilityAdmin {
  id         String @id @default(uuid())
  userId     String
  facilityId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([userId, facilityId])
}

model CheckIn {
  id            String    @id @default(uuid())
  userId        String
  facilityId    String
  clubSessionId String?
  checkInLat    Float?
  checkInLng    Float?
  feeAmount     Int? // guest fee in KRW, null for members / no-fee
  feePaid       Boolean   @default(false)
  checkedInAt   DateTime  @default(now())
  checkedOutAt  DateTime?
  restingAt     DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility    Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  clubSession ClubSession? @relation(fields: [clubSessionId], references: [id], onDelete: SetNull)

  @@index([userId, facilityId])
  @@index([clubSessionId, checkedOutAt])
}

model Club {
  id             String   @id @default(uuid())
  name           String
  inviteCode     String   @unique
  homeFacilityId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  homeFacility Facility?     @relation(fields: [homeFacilityId], references: [id])
  members      ClubMember[]
  sessions     ClubSession[]
  messages     ClubMessage[]
}

model ClubMember {
  id     String         @id @default(uuid())
  userId String
  clubId String
  role   ClubMemberRole @default(MEMBER)
  // Per-club 급수 override set by the club's operator (LEADER/STAFF). When
  // non-null it OVERRIDES the user's own default (PlayerProfile.skillLevel) FOR
  // THIS CLUB ONLY. Null = no override → fall back to the user's own default.
  skillLevel SkillLevel?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

// 모임 채팅/건의(짝 요청). 모임원이 남기는 메시지. type=REQUEST 는 "○○랑 같이
// 치고 싶어요 / 누구랑 짜주세요" 짝 요청 — mentionedUserIds 에 지목한 모임원 id.
model ClubMessage {
  id               String          @id @default(uuid())
  clubId           String
  userId           String
  text             String          @db.VarChar(500)
  type             ChatMessageType @default(CHAT)
  mentionedUserIds String[]        @default([])
  createdAt        DateTime        @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
}

// --- Turn (순번/고깔) system ---

model CourtTurn {
  id            String        @id @default(uuid())
  courtId       String
  position      Int // 1~maxTurnsPerCourt
  status        TurnStatus    @default(WAITING)
  gameType      CourtGameType @default(DOUBLES)
  createdById   String
  clubSessionId String?
  createdAt     DateTime      @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  timeLimitAt   DateTime?

  court           Court             @relation(fields: [courtId], references: [id], onDelete: Cascade)
  createdBy       User              @relation("TurnCreator", fields: [createdById], references: [id])
  clubSession     ClubSession?      @relation(fields: [clubSessionId], references: [id])
  players         TurnPlayer[]
  game            Game?
  gameBoardEntry  GameBoardEntry?

  @@index([courtId, position])
  @@index([courtId, status])
  @@index([clubSessionId])
}

model TurnPlayer {
  id     String @id @default(uuid())
  turnId String
  userId String

  turn CourtTurn @relation(fields: [turnId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([turnId, userId])
}

model Game {
  id        String     @id @default(uuid())
  turnId    String     @unique
  courtId   String
  status    GameStatus @default(IN_PROGRESS)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  turn          CourtTurn      @relation(fields: [turnId], references: [id], onDelete: Cascade)
  court         Court          @relation(fields: [courtId], references: [id], onDelete: Cascade)
  players       GamePlayer[]
  noShowRecords NoShowRecord[]

  @@index([courtId])
}

model GamePlayer {
  id     String @id @default(uuid())
  gameId String
  userId String

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
}

model NoShowRecord {
  id            String    @id @default(uuid())
  userId        String
  gameId        String
  facilityId    String
  occurredAt    DateTime  @default(now())
  penaltyEndsAt DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game     Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([userId, facilityId])
  @@index([userId, penaltyEndsAt])
}

model FacilitySession {
  id         String        @id @default(uuid())
  facilityId String
  openedById String
  status     SessionStatus @default(OPEN)
  openedAt   DateTime      @default(now())
  closedAt   DateTime?
  note       String?

  facility     Facility           @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  openedBy     User               @relation("SessionOpener", fields: [openedById], references: [id])
  clubSessions ClubSession[]

  @@index([facilityId, status])
}

model ScheduledJob {
  id        String   @id @default(uuid())
  type      String
  targetId  String
  executeAt DateTime
  executed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([executed, executeAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// --- Game Board (모임판) ---

enum GameBoardEntryStatus {
  QUEUED // 편성됨, 아직 코트에 안 걸림
  MATERIALIZED // CourtTurn으로 변환됨
  PLAYING // 게임 중
  COMPLETED // 완료
  CANCELLED // 취소
}

model GameBoard {
  id            String   @id @default(uuid())
  clubSessionId String   @unique
  facilityId    String
  createdById   String
  createdAt     DateTime @default(now())

  clubSession ClubSession      @relation(fields: [clubSessionId], references: [id])
  facility    Facility         @relation(fields: [facilityId], references: [id])
  createdBy   User             @relation("GameBoardCreator", fields: [createdById], references: [id])
  entries     GameBoardEntry[]
}

model GameBoardEntry {
  id         String               @id @default(uuid())
  boardId    String
  courtId    String?
  position   Int
  queueOrder Int                  @default(0) // global ordering of the court-less QUEUED queue (다음 게임 순서)
  note       String?
  playerIds  String[]
  status     GameBoardEntryStatus @default(QUEUED)
  turnId     String?              @unique
  createdAt  DateTime             @default(now())

  board GameBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  court Court?     @relation(fields: [courtId], references: [id])
  turn  CourtTurn? @relation(fields: [turnId], references: [id])

  @@index([boardId, position])
  @@index([boardId, queueOrder])
}

// --- Club Session (모임 세션) ---

model ClubSession {
  id                String            @id @default(uuid())
  clubId            String
  facilityId        String
  facilitySessionId String
  startedById       String
  status            ClubSessionStatus @default(ACTIVE)
  courtIds          String[]
  title             String?
  scheduledStartAt  DateTime?
  checkInOpensAt    DateTime?
  checkInClosesAt   DateTime?
  startedAt         DateTime          @default(now())
  endedAt           DateTime?

  club            Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  facility        Facility           @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  facilitySession FacilitySession    @relation(fields: [facilitySessionId], references: [id], onDelete: Cascade)
  startedBy       User               @relation("ClubSessionStarter", fields: [startedById], references: [id])
  courts          Court[]
  turns           CourtTurn[]
  gameBoard       GameBoard?
  checkIns        CheckIn[]

  @@index([clubId, status])
  @@index([facilityId, status])
}
