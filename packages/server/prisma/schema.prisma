generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FACILITY_ADMIN
  CLUB_LEADER
  PLAYER
}

enum CourtStatus {
  EMPTY
  IN_USE
  MAINTENANCE
}

enum GameStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TurnStatus {
  WAITING
  PLAYING
  COMPLETED
  CANCELLED
}

enum FacilityRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum GameType {
  SINGLES
  DOUBLES
  MIXED_DOUBLES
}

enum CourtGameType {
  DOUBLES
  LESSON
}

enum RecruitmentStatus {
  RECRUITING
  FULL
  REGISTERED
  CANCELLED
  EXPIRED
}

enum RotationStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum ClubMemberRole {
  LEADER
  STAFF
  MEMBER
}

enum ClubSessionStatus {
  ACTIVE
  ENDED
}

model User {
  id             String   @id @default(uuid())
  phone          String   @unique
  password       String
  name           String
  role           UserRole @default(PLAYER)
  expoPushToken  String?
  refreshToken   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  facilityAdmins       FacilityAdmin[]
  checkIns             CheckIn[]
  clubMembers          ClubMember[]
  gamePlayers          GamePlayer[]
  notifications        Notification[]
  profile              PlayerProfile?
  noShowRecords        NoShowRecord[]
  openedSessions       FacilitySession[]    @relation("SessionOpener")
  createdTurns         CourtTurn[]          @relation("TurnCreator")
  turnPlayers          TurnPlayer[]
  facilityRequests     FacilityRequest[]    @relation("RequestCreator")
  reviewedRequests     FacilityRequest[]    @relation("RequestReviewer")
  createdRecruitments  GroupRecruitment[]   @relation("RecruitmentCreator")
  recruitmentMembers   RecruitmentMember[]
  createdRotations     RotationSchedule[]   @relation("RotationCreator")
  rotationPlayers      RotationPlayer[]
  startedClubSessions  ClubSession[]        @relation("ClubSessionStarter")
}

model PlayerProfile {
  id                 String     @id @default(uuid())
  userId             String     @unique
  skillLevel         SkillLevel @default(INTERMEDIATE)
  preferredGameTypes GameType[] @default([DOUBLES])
  gender             String?
  birthYear          Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Facility {
  id         String   @id @default(uuid())
  name       String
  address    String
  latitude   Float?
  longitude  Float?
  qrCodeData String   @unique @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  courts        Court[]
  admins        FacilityAdmin[]
  checkIns      CheckIn[]
  policy        FacilityPolicy?
  noShowRecords NoShowRecord[]
  sessions      FacilitySession[]
  recruitments  GroupRecruitment[]
  rotations     RotationSchedule[]
  homeClubs     Club[]
  clubSessions  ClubSession[]
}

model FacilityPolicy {
  id                   String   @id @default(uuid())
  facilityId           String   @unique
  maxTurnsPerCourt     Int      @default(3)
  playersPerTurn       Int      @default(4)
  allowRequeue         Boolean  @default(true)
  noShowPenaltyMinutes Int      @default(30)
  turnNotifyEnabled    Boolean  @default(true)
  gameDurationMinutes  Int?
  gameWarningMinutes   Int?     @default(2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
}

model Court {
  id         String        @id @default(uuid())
  name       String
  facilityId String
  status     CourtStatus   @default(EMPTY)
  gameType   CourtGameType @default(DOUBLES)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  facility      Facility          @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  turns         CourtTurn[]
  games         Game[]
  recruitments  GroupRecruitment[] @relation("TargetCourt")
  rotationSlots RotationSlot[]

  @@unique([facilityId, name])
}

model FacilityAdmin {
  id         String @id @default(uuid())
  userId     String
  facilityId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([userId, facilityId])
}

model CheckIn {
  id           String    @id @default(uuid())
  userId       String
  facilityId   String
  checkedInAt  DateTime  @default(now())
  checkedOutAt DateTime?
  restingAt    DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([userId, facilityId])
}

model Club {
  id             String   @id @default(uuid())
  name           String
  inviteCode     String   @unique
  homeFacilityId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  homeFacility Facility?     @relation(fields: [homeFacilityId], references: [id])
  members      ClubMember[]
  sessions     ClubSession[]
}

model ClubMember {
  id     String         @id @default(uuid())
  userId String
  clubId String
  role   ClubMemberRole @default(MEMBER)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

// --- Turn (순번/고깔) system ---

model CourtTurn {
  id              String        @id @default(uuid())
  courtId         String
  position        Int           // 1~maxTurnsPerCourt
  status          TurnStatus    @default(WAITING)
  gameType        CourtGameType @default(DOUBLES)
  createdById     String
  clubSessionId   String?
  createdAt       DateTime      @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  timeLimitAt     DateTime?

  court              Court             @relation(fields: [courtId], references: [id], onDelete: Cascade)
  createdBy          User              @relation("TurnCreator", fields: [createdById], references: [id])
  clubSession        ClubSession?      @relation(fields: [clubSessionId], references: [id])
  players            TurnPlayer[]
  game               Game?
  fromRecruitment    GroupRecruitment? @relation("RegisteredTurn")

  @@index([courtId, position])
  @@index([courtId, status])
  @@index([clubSessionId])
}

model TurnPlayer {
  id     String @id @default(uuid())
  turnId String
  userId String

  turn CourtTurn @relation(fields: [turnId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([turnId, userId])
}

model Game {
  id        String     @id @default(uuid())
  turnId    String     @unique
  courtId   String
  status    GameStatus @default(IN_PROGRESS)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  turn          CourtTurn    @relation(fields: [turnId], references: [id], onDelete: Cascade)
  court         Court        @relation(fields: [courtId], references: [id], onDelete: Cascade)
  players       GamePlayer[]
  noShowRecords NoShowRecord[]

  @@index([courtId])
}

model GamePlayer {
  id     String @id @default(uuid())
  gameId String
  userId String

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
}

model NoShowRecord {
  id            String    @id @default(uuid())
  userId        String
  gameId        String
  facilityId    String
  occurredAt    DateTime  @default(now())
  penaltyEndsAt DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game     Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([userId, facilityId])
  @@index([userId, penaltyEndsAt])
}

// --- Facility Request ---

model FacilityRequest {
  id           String                @id @default(uuid())
  userId       String
  name         String
  address      String
  status       FacilityRequestStatus @default(PENDING)
  reviewNote   String?
  reviewedById String?
  createdAt    DateTime              @default(now())
  reviewedAt   DateTime?

  user       User  @relation("RequestCreator", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("RequestReviewer", fields: [reviewedById], references: [id])

  @@index([status])
}

model FacilitySession {
  id         String        @id @default(uuid())
  facilityId String
  openedById String
  status     SessionStatus @default(OPEN)
  openedAt   DateTime      @default(now())
  closedAt   DateTime?
  note       String?

  facility     Facility           @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  openedBy     User               @relation("SessionOpener", fields: [openedById], references: [id])
  rotations    RotationSchedule[]
  clubSessions ClubSession[]

  @@index([facilityId, status])
}

model ScheduledJob {
  id        String   @id @default(uuid())
  type      String
  targetId  String
  executeAt DateTime
  executed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([executed, executeAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// --- Group Recruitment (조 모집) ---

model GroupRecruitment {
  id               String            @id @default(uuid())
  facilityId       String
  createdById      String
  gameType         CourtGameType     @default(DOUBLES)
  playersRequired  Int               @default(4)
  targetCourtId    String?
  status           RecruitmentStatus @default(RECRUITING)
  message          String?
  createdAt        DateTime          @default(now())
  expiresAt        DateTime
  registeredTurnId String?           @unique

  facility       Facility           @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  createdBy      User               @relation("RecruitmentCreator", fields: [createdById], references: [id])
  targetCourt    Court?             @relation("TargetCourt", fields: [targetCourtId], references: [id])
  registeredTurn CourtTurn?         @relation("RegisteredTurn", fields: [registeredTurnId], references: [id])
  members        RecruitmentMember[]

  @@index([facilityId, status])
}

model RecruitmentMember {
  id            String   @id @default(uuid())
  recruitmentId String
  userId        String
  joinedAt      DateTime @default(now())

  recruitment GroupRecruitment @relation(fields: [recruitmentId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recruitmentId, userId])
}

// --- Rotation (로테이션/게임 편성) ---

model RotationSchedule {
  id              String          @id @default(uuid())
  facilityId      String
  sessionId       String
  createdById     String
  clubSessionId   String?
  status          RotationStatus  @default(DRAFT)
  totalRounds     Int
  currentRound    Int             @default(0)
  playerCount     Int
  courtCount      Int
  createdAt       DateTime        @default(now())
  startedAt       DateTime?
  completedAt     DateTime?

  facility      Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  session       FacilitySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdBy     User            @relation("RotationCreator", fields: [createdById], references: [id])
  clubSession   ClubSession?    @relation(fields: [clubSessionId], references: [id])
  slots         RotationSlot[]
  players       RotationPlayer[]

  @@index([facilityId, status])
  @@index([clubSessionId])
}

model RotationSlot {
  id            String   @id @default(uuid())
  scheduleId    String
  round         Int
  courtIndex    Int
  courtId       String
  playerIds     String[]
  turnId        String?
  materialized  Boolean  @default(false)
  completed     Boolean  @default(false)

  schedule      RotationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  court         Court            @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, round, courtIndex])
  @@index([scheduleId, round])
}

model RotationPlayer {
  id            String @id @default(uuid())
  scheduleId    String
  userId        String
  gamesAssigned Int    @default(0)
  gamesPlayed   Int    @default(0)
  sittingOut    Int    @default(0)

  schedule      RotationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, userId])
}

// --- Club Session (모임 세션) ---

model ClubSession {
  id                String            @id @default(uuid())
  clubId            String
  facilityId        String
  facilitySessionId String
  startedById       String
  status            ClubSessionStatus @default(ACTIVE)
  courtIds          String[]
  startedAt         DateTime          @default(now())
  endedAt           DateTime?

  club              Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  facility          Facility          @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  facilitySession   FacilitySession   @relation(fields: [facilitySessionId], references: [id], onDelete: Cascade)
  startedBy         User              @relation("ClubSessionStarter", fields: [startedById], references: [id])
  turns             CourtTurn[]
  rotations         RotationSchedule[]

  @@index([clubId, status])
  @@index([facilityId, status])
}
