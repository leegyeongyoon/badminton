# Production environment for docker-compose.prod.yml.
# Copy to `.env.prod` ON THE SERVER ONLY (chmod 600). NEVER commit .env.prod.
#
NODE_ENV=production
PORT=3000

# Bundled Postgres from docker-compose.prod.yml. If you point this at an
# EXISTING/external DB instead, change the host — the deploy script then skips
# starting the bundled Postgres automatically.
DATABASE_URL=postgresql://badminton:badminton@postgres:5432/badminton

# REQUIRED, strong, unique. Generate each with: openssl rand -hex 32
# (config.ts rejects weak/default/short secrets when NODE_ENV=production.)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=7d

# Kakao OAuth (reuse existing dev values unless rotating).
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# Public base URL used for QR-code links. Set to a reachable host/domain.
WEB_BASE_URL=https://badminton.eattable.kr
